generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PHOTOGRAPHER
  CLUB_MEMBER
  VIEWER
}

enum Privacy {
  PUBLIC
  PRIVATE
}

enum MediaType {
  PHOTO
  VIDEO
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  passwordHash    String
  role            Role           @default(VIEWER)
  referenceSelfie String?        // S3 URL
  awsFaceId       String?        // AWS Rekognition Face ID
  events          Event[]
  media           Media[]
  interactions    Interaction[]
  comments        Comment[]
  notifications   Notification[]
}

model Event {
  id          String   @id @default(uuid())
  clubName    String   // Added for dynamic watermarking requirement!
  name        String
  description String?
  date        DateTime
  category    String
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  albums      Album[]
  createdAt   DateTime @default(now())
}

model Album {
  id        String   @id @default(uuid())
  eventId   String
  name      String
  event     Event    @relation(fields: [eventId], references: [id])
  media     Media[]
}

model Media {
  id           String        @id @default(uuid())
  albumId      String
  uploaderId   String
  s3Url        String
  s3Key        String        
  type         MediaType
  size         Int           
  tags         String[]      // Generated by AWS Rekognition
  facesInPhoto String[]      // User IDs detected in photo
  privacy      Privacy       @default(PUBLIC) 
  album        Album         @relation(fields: [albumId], references: [id])
  uploader     User          @relation(fields: [uploaderId], references: [id])
  interactions Interaction[]
  comments     Comment[]
  createdAt    DateTime      @default(now())
}

model Interaction {
  id        String   @id @default(uuid())
  type      String   // "LIKE", "FAVORITE"
  mediaId   String
  userId    String
  media     Media    @relation(fields: [mediaId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([userId, mediaId, type]) // Prevents double-liking
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  mediaId   String
  userId    String
  media     Media    @relation(fields: [mediaId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   
  actor     String   
  action    String   // e.g. "liked your photo", "tagged you"
  mediaId   String?
  isRead    Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
